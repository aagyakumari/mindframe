---
import Layout from '../../layouts/Layout.astro';
import { client, urlFor, ALL_POSTS_QUERY } from '../../lib/sanity';

const posts = await client.fetch(ALL_POSTS_QUERY);

const formatDate = (dateStr: string) =>
  new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
---

<Layout
  title="Blog | Mindframe"
  description="Insights on branding, design, and technology from the Mindframe team."
  navbarClass="bg-white"
>

  <!-- Hero -->
  <section class="bg-white pt-[120px] pb-[60px]">
    <div class="max-w-[1440px] mx-auto px-6 md:px-[99px]">
      <div class="blog-hero opacity-0 text-center">
        <div class="flex items-center justify-center gap-4 md:gap-10 mb-6">
          <div class="h-[1px] w-full md:w-[240px] bg-[#1D375C]"></div>
          <span class="text-[14px] font-medium text-[#38BDF8] whitespace-nowrap">Our Blog</span>
          <div class="h-[1px] w-full md:w-[240px] bg-[#1D375C]"></div>
        </div>
        <h1 class="text-[40px] md:text-[64px] font-medium text-[#1D375C] leading-[110%] mb-4">
          Ideas & Insights
        </h1>
        <p class="text-[16px] font-light text-[#1D375C] opacity-60 max-w-[480px] mx-auto leading-relaxed">
          Perspectives on branding, design, and technology from the Mindframe team.
        </p>
      </div>
    </div>
  </section>

  <!-- Posts -->
  <section class="bg-white pb-[90px]">
    <div class="max-w-[1100px] mx-auto px-6 md:px-[85px]">

      {posts.length === 0 ? (
        <div class="text-center py-24">
          <p class="text-[#1D375C] opacity-40 text-[16px] font-light">
            No posts published yet — check back soon.
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post: any, i: number) => (
            <a
              href={`/blog/${post.slug}`}
              class="blog-card group bg-white rounded-[16px] overflow-hidden shadow-[0_2px_16px_rgba(29,55,92,0.08)] hover:shadow-[0_8px_40px_rgba(56,189,248,0.15)] transition-all duration-300 opacity-0 flex flex-col"
            >
              <!-- Cover Image -->
              <div class="mx-3 mt-3 rounded-[10px] h-[190px] flex-none overflow-hidden bg-[#E4EFFF]">
                {post.mainImage ? (
                  <img
                    src={urlFor(post.mainImage).width(800).height(400).url()}
                    alt={post.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-[#E4EFFF]">
                    <svg class="w-10 h-10 text-[#38BDF8] opacity-40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3 21h18M3 3h18"/>
                    </svg>
                  </div>
                )}
              </div>

              <!-- Content -->
              <div class="px-5 pt-5 pb-5 flex flex-col flex-1">

                <!-- Title -->
                <h2 class="text-[16px] font-semibold text-[#1D375C] leading-[145%] mb-3 group-hover:text-[#38BDF8] transition-colors duration-200">
                  {post.title}
                </h2>

                <!-- Excerpt -->
                {post.excerpt && (
                  <p class="text-[13px] text-[#1D375C] opacity-50 leading-relaxed mb-5 flex-1 font-light line-clamp-3">
                    {post.excerpt}
                  </p>
                )}

                <!-- Read article link -->
                <div class="flex items-center gap-1 text-[13px] font-medium text-[#38BDF8] mb-5">
                  Read article
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"/>
                  </svg>
                </div>

                <!-- Divider -->
                <div class="border-t border-[#EEF3FA]"></div>

                <!-- Author + Date -->
                <div class="flex items-center justify-between pt-4">
                  <span class="text-[12px] text-[#1D375C] opacity-40 font-light">{post.author ?? 'Mindframe Team'}</span>
                  <span class="text-[12px] text-[#1D375C] opacity-40 font-light">{post.publishedAt ? formatDate(post.publishedAt) : ''}</span>
                </div>

              </div>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>

</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const init = () => {
    gsap.to('.blog-hero', {
      opacity: 1, y: 0, duration: 1, ease: 'power3.out', startAt: { y: 30 }
    });
    gsap.to('.blog-card', {
      opacity: 1, y: 0, duration: 0.7, stagger: 0.1, ease: 'power2.out',
      startAt: { y: 30 },
      scrollTrigger: { trigger: '.blog-card', start: 'top 88%' }
    });
  };

  init();
  document.addEventListener('astro:after-swap', () => { init(); ScrollTrigger.refresh(); });
</script>
