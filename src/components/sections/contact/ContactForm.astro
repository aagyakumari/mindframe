<section class="bg-[#E4EFFF] pt-[40px] md:pt-[60px] pb-[90px] relative overflow-hidden">

  <div class="max-w-[1440px] mx-auto px-6 md:px-[99px]">

    <!-- Section Label -->
    <div class="contact-label flex items-center justify-center gap-4 md:gap-10 mb-[40px] opacity-0">
      <div class="h-[1px] w-full md:w-[240px] bg-[#1D375C]"></div>
      <span class="text-[14px] font-medium text-[#38BDF8] whitespace-nowrap">
        Contact
      </span>
      <div class="h-[1px] w-full md:w-[240px] bg-[#1D375C]"></div>
    </div>

    <!-- Main Heading -->
    <div class="contact-heading text-center mb-[40px] opacity-0">
      <h2 class="text-[32px] md:text-[40px] font-medium text-[#1D375C] leading-[120%]">
        Ready to Reframe <br class="hidden md:block" />
        Your Future?
      </h2>
    </div>

    <!-- Illustration + Card Wrapper -->
    <div class="relative max-w-[591px] mx-auto mt-[160px] md:mt-[164px]">

      <!-- Illustration -->
      <div class="contact-illustration absolute -top-[70px] md:-top-[100px] left-1/2 -translate-x-1/2 z-20 w-[300px] md:w-[380px]">
        <img 
          src="/contact.svg" 
          alt="Contact Illustration" 
          class="w-full h-auto object-contain"
        />
      </div>

      <!-- Form Card -->
      <div class="contact-form-card bg-white pt-[60px] md:pt-[60px] pb-[60px] px-[40px] md:px-[60px]
                  shadow-[0_20px_60px_rgba(208,226,255,0.7)]
                  relative z-10 text-left rounded-[4px] opacity-0">

        <h3 class="text-[28px] md:text-[32px] font-medium text-[#1D375C] text-center mb-[12px]">
          Drop Your Message
        </h3>

        <p class="text-[14px] font-light text-[#1D375C] text-center mb-[40px] leading-relaxed max-w-[400px] mx-auto opacity-70">
          Fill out the form below and our team will get back to you within 24 - 48 hours.
        </p>

        <form class="space-y-6">

          <!-- Row 1 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <input 
              type="text" 
              placeholder="First Name" 
              class="contact-input w-full h-[52px] px-[24px] border border-[#CFCFCF] focus:border-[#38BDF8] outline-none text-[14px] font-light text-[#1D375C] placeholder:text-[#1D375C] placeholder:font-light opacity-0"
            />
            <input 
              type="text" 
              placeholder="Last Name" 
              class="contact-input w-full h-[52px] px-[24px] border border-[#CFCFCF] focus:border-[#38BDF8] outline-none text-[14px] font-light text-[#1D375C] placeholder:text-[#1D375C] placeholder:font-light opacity-0"
            />
          </div>

          <!-- Row 2 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <input 
              type="email" 
              placeholder="Email Address" 
              class="contact-input w-full h-[52px] px-[24px] border border-[#CFCFCF] focus:border-[#38BDF8] outline-none text-[14px] font-light text-[#1D375C] placeholder:text-[#1D375C] placeholder:font-light opacity-0"
            />
            <input 
              type="tel" 
              placeholder="Phone Number" 
              class="contact-input w-full h-[52px] px-[24px] border border-[#CFCFCF] focus:border-[#38BDF8] outline-none text-[14px] font-light text-[#1D375C] placeholder:text-[#1D375C] placeholder:font-light opacity-0"
            />
          </div>

          <!-- Company -->
          <input 
            type="text" 
            placeholder="Company Name" 
            class="contact-input w-full h-[52px] px-[24px] border border-[#CFCFCF] focus:border-[#38BDF8] outline-none text-[14px] font-light text-[#1D375C] placeholder:text-[#1D375C] placeholder:font-light opacity-0"
          />

          <!-- Message -->
          <textarea 
            placeholder="Message" 
            rows="5"
            class="contact-input w-full px-[24px] py-[16px] border border-[#CFCFCF] focus:border-[#38BDF8] outline-none text-[14px] font-light text-[#1D375C] placeholder:text-[#1D375C] placeholder:font-light resize-none opacity-0"
          ></textarea>

          <!-- Submit -->
          <button 
            type="submit"
            class="contact-submit w-full h-[55px] bg-[#38BDF8] text-white font-bold text-[20px] hover:bg-[#20A9E7] transition-all shadow-md mt-4 opacity-0"
          >
            Submit
          </button>

        </form>

      </div>

    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initContactForm = () => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '.contact-label',
        start: 'top 85%'
      }
    });

    // Label and Heading
    tl.to(['.contact-label', '.contact-heading'], {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.2,
      ease: 'power3.out',
      startAt: { y: 20 }
    })
    // Form Card Entrance
    .to('.contact-form-card', {
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out',
      startAt: { y: 50 }
    }, '-=0.5')

    // Staggered Form Inputs
    .to('.contact-input', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.1,
      ease: 'power2.out',
      startAt: { y: 20 }
    }, '-=0.5')
    // Submit Button
    .to('.contact-submit', {
      opacity: 1,
      scale: 1,
      duration: 0.8,
      ease: 'back.out(1.7)',
      startAt: { scale: 0.9 }
    }, '-=0.3');


  };

  // Initialize
  initContactForm();
  
  // Re-initialize on Astro navigation
  document.addEventListener('astro:after-swap', () => {
    initContactForm();
    ScrollTrigger.refresh();
  });
</script>