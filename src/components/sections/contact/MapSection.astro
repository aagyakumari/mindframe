---
---

<!-- Info Bar (above map) -->
<div class="bg-[#E4EFFF] pb-[40px] md:pb-[60px] px-6 md:px-[99px]">
  <div class="max-w-[1440px] mx-auto">
    <!-- Divider -->
    <div class="map-divider h-[1px] bg-[#CFCFCF] w-full mb-[28px] origin-left scale-x-0"></div>

    <!-- Info Row -->
    <div class="map-info-row flex flex-col md:flex-row items-start md:items-center justify-between gap-6 opacity-0">
      <!-- Business Hours -->
      <div class="flex items-start gap-3">
        <!-- Clock Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mt-[2px] flex-shrink-0 text-[#1D375C]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
        </svg>
        <div>
          <p class="text-[16px] font-medium text-[#000000] leading-tight">Sun - Fri</p>
          <p class="text-[16px] font-medium text-[#000000] leading-tight">10:00 am to 5:00 pm</p>
        </div>
      </div>

      <!-- Social Media -->
      <div class="flex items-center gap-4">
        <span class="text-[16px] font-medium text-[#000000]">Social Media</span>
        <!-- LinkedIn -->
        <a href="https://www.linkedin.com/company/mindframe-technologies/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-[#1D375C] hover:opacity-70 transition-opacity">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
        <!-- Instagram -->
        <a href="https://www.instagram.com/mindframetech/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-[#1D375C] hover:opacity-70 transition-opacity">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Map -->
<section class="map-container w-full h-[300px] md:h-[500px] relative bg-[#f5f5f5] opacity-0">
  <iframe
    src="https://www.google.com/maps?q=27.748612,85.347020&z=17&output=embed"
    class="w-full h-full"
    style="border:0;"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initMapSection = () => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '.map-divider',
        start: 'top 90%'
      }
    });

    tl.to('.map-divider', {
      scaleX: 1,
      duration: 1,
      ease: 'power3.inOut'
    })
    .to('.map-info-row', {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power3.out',
      startAt: { y: 20 }
    }, '-=0.5')
    .to('.map-container', {
      opacity: 1,
      duration: 1.2,
      ease: 'power2.out'
    }, '-=0.3');
  };

  // Initialize
  initMapSection();

  // Re-initialize on Astro navigation
  document.addEventListener('astro:after-swap', () => {
    initMapSection();
    ScrollTrigger.refresh();
  });
</script>
