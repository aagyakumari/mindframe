<section class="bg-white pt-[40px] md:pt-[50px] pb-[20px] md:pb-[30px] text-center">
  <div class="max-w-[1440px] mx-auto px-6 md:px-[99px]">
    <!-- Main Heading (Figma: Large, weight 500) -->
    <h1 class="services-title text-[48px] md:text-[84px] font-medium text-[var(--color-primary)] leading-[1.1] opacity-0">
      Services
    </h1>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  window.addEventListener('load', () => {
    gsap.to('.services-title', {
      opacity: 1,
      y: 0,
      duration: 1,
      delay: 0.2,
      ease: 'power3.out',
      startAt: { y: 30 }
    });
  });
</script>
