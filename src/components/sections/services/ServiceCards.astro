---

<section class="bg-[var(--color-bg)] pt-[40px] md:pt-[60px] pb-[100px] md:pb-[160px] relative overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 md:px-[99px]">
    
    <!-- Section Label -->
    <div class="services-label flex items-center justify-center gap-4 md:gap-10 mb-[40px] opacity-0">
      <div class="h-[1px] w-full md:w-[240px] bg-[#1D375C]"></div>
      <span class="text-[14px] font-medium text-[#38BDF8] whitespace-nowrap">
        Service
      </span>
      <div class="h-[1px] w-full md:w-[240px] bg-[#1D375C]"></div>
    </div>

    <!-- Headers -->
    <div class="services-header text-center mb-[40px] opacity-0">
      <h2 class="text-[28px] md:text-[36px] font-medium text-[var(--color-primary)] mb-[10px]">
        Our Services
      </h2>
      <p class="text-[18px] md:text-[24px] font-light text-[#1D375C] max-w-[700px] mx-auto leading-[1.4]">
        Reliable, scalable, and tailored software services.
      </p>
    </div>

    <!-- Service Grid (Flex for 3-up, 2-down centering) -->
    <div class="max-w-[840px] mx-auto flex flex-wrap justify-center gap-[24px]">
      {services.map((service) => (
        <div class="service-card group relative w-[261px] h-[336px] p-[24px] rounded-none flex flex-col items-start transition-all duration-300 opacity-0
                    bg-white text-black shadow-[0_10px_40px_rgba(208,226,255,0.7)] border border-[#F0F7FF]
                    hover:bg-[#1D375C] hover:text-white hover:border-white hover:border-[3px]">
          
          <div class="w-full flex justify-between items-start">
            <span class="text-[64px] font-medium leading-[1] text-black group-hover:text-white transition-colors">
              {service.id}
            </span>
            <!-- Icon from data (Matches user naming convention) -->
            <div class="w-[48px] h-[48px] flex items-center justify-center rounded-lg bg-[#E4EFFF] group-hover:bg-white/10 shrink-0 transition-all">
               <img 
                 src={`/${service.id}.svg`} 
                 alt={service.title} 
                 class="w-[32px] h-[32px] object-contain brightness-0 group-hover:invert transition-all"
               />
            </div>
          </div>

          <h3 class="mt-[40px] text-[16px] font-bold leading-none text-black group-hover:text-white transition-colors">
            {service.title}
          </h3>
          
          <p class="mt-[12px] text-[10px] font-light leading-[1.4] text-black group-hover:text-white/80 max-w-[211px] transition-colors">
            {service.description}
          </p>

          <a href="#" class="mt-auto w-[140px] h-[38px] flex items-center justify-center rounded-none text-[10px] font-bold transition-all
                            bg-[#38BDF8] text-white hover:bg-[#38BDF8]/90 shadow-sm
                            group-hover:bg-white group-hover:text-[#1D375C]">
            Case Study
          </a>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initAnimations = () => {
    // Label and Header
    gsap.to(['.services-label', '.services-header'], {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.2,
      ease: 'power3.out',
      startAt: { y: 20 },
      scrollTrigger: {
        trigger: '.services-header',
        start: 'top 85%'
      }
    });

    // Staggered Cards
    gsap.to('.service-card', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power3.out',
      startAt: { y: 40 },
      scrollTrigger: {
        trigger: '.service-card',
        start: 'top 85%'
      }
    });
  };

  window.addEventListener('load', initAnimations);
  document.addEventListener('astro:after-swap', initAnimations);
</script>
