---
---

<section class="bg-white min-h-auto md:h-[479px] py-[60px] md:py-0 relative overflow-hidden">
  
  <!-- Decorative Background Elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="cta-bg-circle absolute top-[-100px] left-[-100px] w-[400px] h-[400px] rounded-full bg-[#38BDF8]/5 blur-[80px]"></div>
    <div class="cta-bg-circle absolute bottom-[-50px] right-[10%] w-[300px] h-[300px] rounded-full bg-[#1D375C]/5 blur-[60px]"></div>
  </div>

  <div class="max-w-[1440px] mx-auto px-6 md:px-[99px] h-full relative z-10">
    <div class="flex flex-col md:flex-row items-center md:items-start justify-center gap-12 md:gap-[130px] h-full">
      
      <!-- Left: Illustration -->
      <div class="cta-illustration relative w-full max-w-[592px] shrink-0 md:pt-[20px] opacity-0">
        <img 
          src="/laptop.svg" 
          alt="Working at Laptop" 
          class="w-full h-auto object-contain relative z-10"
        />
        <!-- Subtle shadow for the floating effect -->
        <div class="cta-shadow absolute bottom-[10px] left-1/2 -translate-x-1/2 w-[60%] h-[20px] bg-black/5 blur-xl rounded-[100%] opacity-0"></div>
      </div>

      <!-- Right: Text Content -->
      <div class="cta-content w-full md:max-w-[442px] text-center md:text-left md:pt-[81px]">
        <h2 class="cta-heading text-[32px] md:text-[40px] font-medium leading-[1.2] md:leading-[1.3] text-[#1D375C] mb-[32px] opacity-0">
          Interested in starting a project with us?
        </h2>
        
        <div class="cta-btn-wrapper opacity-0">
          <a href="/contact" class="inline-flex items-center gap-4 text-[18px] md:text-[20px] font-bold text-[#1D375C] hover:text-[#38BDF8] transition-all group">
            Contact Us
            <span class="w-[40px] h-[40px] md:w-[48px] md:h-[48px] rounded-full bg-[#38BDF8] flex items-center justify-center text-white transition-transform group-hover:translate-x-2">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </span>
          </a>
        </div>
      </div>

    </div>
  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initCTAAnimations = () => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '.cta-illustration',
        start: 'top 80%'
      }
    });

    // Entrance Animation
    tl.to('.cta-illustration', {
      opacity: 1,
      x: 0,
      rotate: 0,
      scale: 1,
      duration: 1.4,
      ease: 'expo.out',
      startAt: { x: -80, rotate: -5, scale: 0.9 }
    })
    .to(['.cta-heading', '.cta-btn-wrapper'], {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.2,
      ease: 'power3.out',
      startAt: { y: 30 }
    }, '-=0.8')
    .to('.cta-shadow', {
      opacity: 1,
      duration: 1
    }, '-=1');

    // Floating Idle Animation for the Illustration
    gsap.to('.cta-illustration img', {
      y: -15,
      duration: 2.5,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });

    // Shadow pulse that matches floating
    gsap.to('.cta-shadow', {
      scale: 1.1,
      opacity: 0.3,
      duration: 2.5,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });

    // Background drifting circles
    gsap.to('.cta-bg-circle', {
      x: 'random(-20, 20)',
      y: 'random(-20, 20)',
      duration: 'random(4, 7)',
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      stagger: 0.5
    });
  };

  window.addEventListener('load', initCTAAnimations);
  document.addEventListener('astro:after-swap', initCTAAnimations);
</script>
