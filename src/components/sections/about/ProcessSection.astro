---
---

<section class="max-w-[1440px] mx-auto px-6 md:px-[99px] pt-[40px] md:pt-[60px] pb-[80px] md:pb-[120px]">
  
  <!-- Heading Section -->
  <div class="w-full text-center mb-[80px]">
    <h2 class="text-[#1D375C] font-medium text-[28px] md:text-[36px] leading-tight">
      Our Process
    </h2>
  </div>

  <!-- Process Layout Wrapper -->
  <div class="flex flex-col w-full relative">
    
    <!-- Top Text Row + Connecting Dotted Line (Desktop) -->
    <div class="relative hidden md:flex items-center justify-between mb-12">
      <!-- Dotted Line Background -->
      <div class="absolute top-[40%] left-[10%] right-[10%] border-b-2 border-dotted border-[#1D375C] opacity-20 -z-10"></div>
      
      <!-- Text Items (Stacked Number and Label) -->
      <div class="flex flex-col items-center bg-white px-10 text-center">
        <span class="text-[#1D375C] font-light text-[36px] leading-none mb-1">01</span>
        <span class="text-[#1D375C] font-light text-[36px] leading-none">Discover</span>
      </div>
      <div class="flex flex-col items-center bg-white px-10 text-center">
        <span class="text-[#1D375C] font-light text-[36px] leading-none mb-1">02</span>
        <span class="text-[#1D375C] font-light text-[36px] leading-none">Strategize</span>
      </div>
      <div class="flex flex-col items-center bg-white px-10 text-center">
        <span class="text-[#1D375C] font-light text-[36px] leading-none mb-1">03</span>
        <span class="text-[#1D375C] font-light text-[36px] leading-none">Execute</span>
      </div>
    </div>

    <!-- Images / Mobile Grid -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-12 md:gap-8">
      
      <!-- Step 1 -->
      <div class="flex flex-col items-center flex-1">
        <div class="md:hidden flex flex-col items-center mb-6 text-center">
          <span class="text-[#1D375C] font-light text-[36px] leading-none mb-1">01</span>
          <span class="text-[#1D375C] font-light text-[36px] leading-none">Discover</span>
        </div>
        <img src="/discover.svg" alt="Discover Process" class="w-full max-w-[395px] h-auto object-contain" />
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col items-center flex-1">
        <div class="md:hidden flex flex-col items-center mb-6 text-center">
          <span class="text-[#1D375C] font-light text-[36px] leading-none mb-1">02</span>
          <span class="text-[#1D375C] font-light text-[36px] leading-none">Strategize</span>
        </div>
        <img src="/strategize.svg" alt="Strategize Process" class="w-full max-w-[395px] h-auto object-contain" />
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col items-center flex-1">
        <div class="md:hidden flex flex-col items-center mb-6 text-center">
          <span class="text-[#1D375C] font-light text-[36px] leading-none mb-1">03</span>
          <span class="text-[#1D375C] font-light text-[36px] leading-none">Execute</span>
        </div>
        <img src="/execute.svg" alt="Execute Process" class="w-full max-w-[320px] h-auto object-contain" />
      </div>

    </div>

  </div>

</section>
