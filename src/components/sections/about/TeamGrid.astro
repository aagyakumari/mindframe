---
const team = [
  { name: 'Dennish', image: '/dennis.svg' },
  { name: 'Obin', image: '/obin.svg' },
  { name: 'Aagya', image: '/aagya.svg' },
  { name: 'Agrata', image: '/agrata.svg' },
  { name: 'Sagar', image: '/sagar.svg' },
  { name: 'Sushan', image: '/susan.svg' },
  { name: 'Pranab', image: '/pranab.svg' },
  { name: 'Utkrista', image: '/utkrista.svg' }
];
---

<section class="max-w-[1440px] mx-auto px-6 md:px-[99px] pt-[40px] md:pt-[60px] pb-[100px] md:pb-[140px]">
  
  <!-- Heading Section -->
  <div class="team-header w-full text-center mb-[60px] md:mb-[80px] opacity-0">
    <h2 class="text-[#1D375C] font-medium text-[28px] md:text-[36px] leading-tight">
      Meet Our Team
    </h2>
  </div>

  <!-- Team Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-[40px] gap-y-[100px] justify-items-center items-end">
    
    {team.map((member) => (
      <div class="team-card flex flex-col items-center group cursor-pointer w-full max-w-[280px] opacity-0">
        <!-- Image Container with Background Square -->
        <div class="w-full relative aspect-square mb-6 flex items-end justify-center overflow-visible">
          
          <!-- Colored Background Block -->
          <div class="absolute bottom-0 left-0 right-0 h-[78%] bg-[#A8B8D0] -z-10 transition-transform duration-500 group-hover:scale-[1.03] rounded-sm"></div>
          
           <!-- Portrait Image (Natural Grounding) -->
           <img 
            src={member.image} 
            alt={`Portrait of ${member.name}`} 
            class="w-full h-auto max-h-[115%] object-bottom object-contain transition-transform duration-500 group-hover:scale-[1.05] z-10" 
          />
        </div>
        
        <!-- Name -->
        <h3 class="text-[#1D375C] font-medium text-[20px] md:text-[24px] text-center group-hover:text-[#38BDF8] transition-colors">
          {member.name}
        </h3>
      </div>
    ))}

  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initTeam = () => {
    // Header
    gsap.to('.team-header', {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power3.out',
      startAt: { y: 20 },
      scrollTrigger: {
        trigger: '.team-header',
        start: 'top 85%'
      }
    });

    // Cards Stagger
    gsap.to('.team-card', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power3.out',
      startAt: { y: 40 },
      scrollTrigger: {
        trigger: '.team-card',
        start: 'top 80%'
      }
    });
  };

  window.addEventListener('load', initTeam);
  document.addEventListener('astro:after-swap', initTeam);
</script>
