---

<section class="max-w-[1440px] mx-auto px-6 md:px-[99px] pt-[40px] md:pt-[60px] pb-[60px] md:pb-[80px]">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-[40px] lg:gap-[80px] items-center">
    
    <!-- Text Column -->
    <div class="flex flex-col text-left">
      <!-- Blue Label -->
      <h3 class="text-[#22B0FF] font-normal text-[20px] md:text-[24px] tracking-wide mb-4">
        Why MindFrame
      </h3>

      <!-- Heading -->
      <h2 class="text-[#1D375C] font-medium text-[28px] md:text-[36px] leading-tight mb-6 max-w-[570px]">
        Why MindFrame Is the Strategic Partner Your Business Needs to Think Smarter and Grow Stronger
      </h2>

      <!-- Paragraph -->
      <p class="text-[#1D375C] font-normal text-[20px] md:text-[24px] leading-none max-w-[591px]">
        We combine clarity, creativity, and data-driven strategy to transform complex challenges into structured, measurable opportunities for long-term success.
      </p>
    </div>

    <!-- Image Column -->
    <div class="flex justify-center lg:justify-end">
      <div class="relative group">
        <!-- Figma Rectangular Glow Effect (Rectangle 226: 548x405, color #E4EFFF, blur 80) -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[548px] h-[405px] bg-[#E4EFFF] blur-[80px] z-0 opacity-100"></div>
        <img src="/why.svg" alt="Why MindFrame Illustration" class="w-full max-w-[485.97px] h-auto object-contain relative z-10" />
      </div>
    </div>

  </div>
</section>
