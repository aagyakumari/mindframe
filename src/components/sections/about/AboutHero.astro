---
import NeuralCanvas from "../../ui/NeuralCanvas.astro";
---

<section class="relative bg-[var(--color-bg)] pt-[40px] md:pt-[50px] pb-[20px] md:pb-[30px] text-center overflow-hidden">
  <NeuralCanvas />
  <div class="max-w-[1440px] mx-auto px-6 md:px-[99px] relative z-10">
    <h1 class="about-title text-[48px] md:text-[84px] font-medium text-[var(--color-primary)] leading-[1.1] opacity-0">
      About Us
    </h1>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const initHero = () => {
    gsap.to('.about-title', {
      opacity: 1,
      y: 0,
      duration: 1,
      delay: 0.2,
      ease: 'power3.out',
      startAt: { y: 30 }
    });
  };

  window.addEventListener('load', initHero);
  document.addEventListener('astro:after-swap', initHero);
</script>
