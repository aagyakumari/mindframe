---

<section class="max-w-[1440px] mx-auto px-6 md:px-[99px] pt-[40px] md:pt-[60px] pb-[60px] md:pb-[80px]">
  
  <div class="flex flex-col items-center">
    
    <!-- Title Area (Centered) -->
    <div class="w-full text-center mb-[60px]">
      <!-- Section Label -->
      <div class="flex items-center justify-center gap-4 md:gap-10 mb-[40px]">
        <div class="h-[1px] w-full md:w-[240px] bg-[#1D375C]"></div>
        <span class="text-[14px] font-medium text-[#38BDF8] whitespace-nowrap">
          About
        </span>
        <div class="h-[1px] w-full md:w-[240px] bg-[#1D375C]"></div>
      </div>

      <h2 class="text-[28px] md:text-[36px] font-medium text-[var(--color-primary)] mb-[10px]">
        Who We Are
      </h2>

      <p class="text-[20px] md:text-[24px] font-light text-[#1D375C] max-w-[833px] mx-auto leading-none">
        At <span class="text-[#38BDF8] font-medium">MindFrame</span>, we combine strategic thinking, creative insight, and purposeful execution to help businesses unlock clarity, drive growth, and achieve meaningful impact.
      </p>
    </div>

    <!-- Illustration Area -->
    <div class="w-full flex justify-center mt-4">
      <img src="/who.svg" alt="Who We Are Illustration" class="w-full max-w-[661px] h-auto" />
    </div>
    
  </div>

</section>
