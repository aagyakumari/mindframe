---
---

<section id="ideas-section" class="bg-white pt-[80px] md:pt-[120px] pb-0 relative overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 md:px-[99px] text-center flex flex-col items-center">

    <!-- Section Label -->
    <div id="ideas-label" class="flex items-center justify-center gap-4 md:gap-10 mb-[40px]">
      <div class="h-[1px] w-[60px] md:w-[240px] bg-[#1D375C]"></div>
      <span class="text-[14px] font-medium text-[#38BDF8] whitespace-nowrap">Our Work</span>
      <div class="h-[1px] w-[60px] md:w-[240px] bg-[#1D375C]"></div>
    </div>

    <!-- Heading -->
    <h2 id="ideas-heading" class="text-[28px] md:text-[36px] font-medium leading-[1.4] text-[var(--color-primary)] mb-[24px] md:mb-[40px] max-w-[415px] mx-auto">
      Where Ideas Become Systems
    </h2>

    <!-- Description -->
    <p id="ideas-body" class="text-[18px] md:text-[24px] font-light text-[#1D375C] max-w-[723px] mx-auto mb-[40px] md:mb-[50px] leading-[1.5] px-4">
      We take ambitious ideas and transform them into structured brand,
      design, and digital systems that create clarity, consistency,
      and measurable growth.
    </p>

    <!-- CTA Button -->
    <a id="ideas-cta" href="/contact"
       class="flex items-center justify-center w-[180px] md:w-[211px] h-[48px] md:h-[50px] bg-[#1D375C] text-white text-[18px] md:text-[24px] font-medium rounded-[35.5px] hover:bg-[#254675] transition-all shadow-sm">
      Get Started
    </a>

  </div>
</section>

<script type="module" is:inline>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener("load", () => {
    const tl = gsap.timeline({
      scrollTrigger: { trigger: '#ideas-section', start: 'top 75%', once: true },
    });

    tl.from('#ideas-label',   { opacity: 0, y: 24, duration: 0.65, ease: 'power3.out' })
      .from('#ideas-heading', { opacity: 0, y: 32, duration: 0.7,  ease: 'power3.out' }, '-=0.45')
      .from('#ideas-body',    { opacity: 0, y: 32, duration: 0.7,  ease: 'power3.out' }, '-=0.45')
      .from('#ideas-cta',     { opacity: 0, y: 20, scale: 0.92, duration: 0.6, ease: 'back.out(1.7)' }, '-=0.35');
  });
</script>
