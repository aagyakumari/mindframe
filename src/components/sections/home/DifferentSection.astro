---
---

<section id="different-section" class="bg-white pt-[80px] md:pt-[120px] pb-0 relative overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 md:px-[99px] text-center flex flex-col items-center">

    <!-- Section Label -->
    <div id="diff-label" class="flex items-center justify-center gap-4 md:gap-10 mb-[40px]">
      <div class="h-[1px] w-[60px] md:w-[240px] bg-[#1D375C]"></div>
      <span class="text-[14px] font-medium text-[#38BDF8] whitespace-nowrap">Built Different</span>
      <div class="h-[1px] w-[60px] md:w-[240px] bg-[#1D375C]"></div>
    </div>

    <h2 id="diff-heading" class="text-[28px] md:text-[36px] font-medium leading-[1.2] text-[var(--color-primary)] mb-[24px] md:mb-[32px] max-w-[497px] mx-auto">
      What Makes Us Different
    </h2>

    <p id="diff-body" class="text-[18px] md:text-[20px] font-light text-[#1D375C] max-w-[573px] mx-auto mb-[20px] leading-[1.5] px-4">
      At MindFrame, we believe the impossible is possible - together.
      Join us today to help us inspire teamwork anywhere and everywhere,
      worldwide.
    </p>

    <!-- Details (Clouds & Plane) -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden max-w-[1440px] mx-auto">
      <!-- Top Left Cloud (desktop only) -->
      <img
        id="diff-cloud-top-left"
        src="/cloud.svg"
        alt=""
        class="hidden md:block absolute top-[20%] left-[15%] w-[200px]"
      />
      <!-- Bottom Left Cloud (desktop only) -->
      <img
        id="diff-cloud-bottom-left"
        src="/cloud.svg"
        alt=""
        class="hidden md:block absolute top-[45%] left-[10%] w-[150px]"
      />
      <!-- Top Right Cloud (desktop only) -->
      <img
        id="diff-cloud-right"
        src="/cloud.svg"
        alt=""
        class="hidden md:block absolute top-[28%] right-[10%] w-[280px]"
      />
      <!-- Plane Container (desktop only — flies right → left) -->
      <div id="diff-plane-container" class=" md:block absolute top-[32%] left-0 w-[100px] md:w-[130px] origin-center z-0">
        <!-- Plane Image (vertical bob) -->
        <img
          id="diff-plane"
          src="/plane.svg"
          alt=""
          class="w-full h-full"
        />
      </div>
    </div>

    <!-- Illustration -->
    <div id="diff-illustration" class="relative w-full max-w-[1204.52px] aspect-[1204.52/659.13] translate-y-[30px] md:translate-y-[50px] -mb-[30px] md:-mb-[50px] z-10">
      <img
        src="/different.svg"
        alt="Team Illustration"
        class="w-full h-full object-contain"
      />
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const initDifferent = () => {
    // Entrance animation
    const tl = gsap.timeline({
      scrollTrigger: { trigger: '#different-section', start: 'top 78%', once: true },
    });
    tl.from('#diff-label',   { opacity: 0, y: 24, duration: 0.65, ease: 'power3.out' })
      .from('#diff-heading', { opacity: 0, y: 32, duration: 0.7,  ease: 'power3.out' }, '-=0.45')
      .from('#diff-body',    { opacity: 0, y: 28, duration: 0.7,  ease: 'power3.out' }, '-=0.45');

    // Plane: fly from right to left, looping continuously
    const planeContainer = document.getElementById('diff-plane-container');
    if (planeContainer) {
      gsap.killTweensOf(planeContainer);
      gsap.killTweensOf('#diff-plane');

      gsap.fromTo(
        planeContainer,
        { x: window.innerWidth + 160 },
        {
          x: -(planeContainer.offsetWidth + 20),
          duration: 14,
          ease: 'none',
          repeat: -1,
          repeatDelay: 2,
        }
      );

      // Gentle vertical bob on the plane image itself
      gsap.to('#diff-plane', {
        y: -12,
        duration: 2,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
      });
    }
  };

  initDifferent();
  document.addEventListener('astro:after-swap', initDifferent);
</script>
