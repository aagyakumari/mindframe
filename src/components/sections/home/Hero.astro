---
import NeuralCanvas from "../../ui/NeuralCanvas.astro";
---

<section id="hero-section" class="relative pt-[40px] md:pt-[70px] pb-[80px] md:pb-[120px] bg-[var(--color-bg)] transition-colors duration-[700ms] ease-in-out overflow-hidden group">
  <NeuralCanvas />
  

  <div class="max-w-[1440px] mx-auto relative z-10">

    <!-- Heading Block -->
    <div class="relative max-w-[773px] mx-auto text-center">

      <h1 class="text-[32px] md:text-[48px] lg:text-[64px] font-semibold leading-[1.1] md:leading-[100%]
                 text-[var(--color-primary)] transition-colors duration-[700ms] hero-title">
        Empower Your Business
      </h1>

      <!-- Hanging Lamp Container -->
      <div class="hidden md:block absolute top-[35px] lg:top-[55px] right-[20px] lg:right-[68px] z-20">
        <div class="relative">
          <!-- Lamp Glow (Hidden in Day, Glows in Night) -->
          <div class="lamp-glow absolute bottom-[-5px] left-1/2 -translate-x-1/2 w-[120px] h-[120px] 
                     bg-radial-gradient from-[rgba(255,215,0,0.4)] via-[rgba(255,215,0,0.1)] to-transparent 
                     opacity-0 blur-2xl transition-opacity duration-1000 pointer-events-none"></div>
          
          <img
            src="/lamp.svg"
            alt="Lamp"
            class="w-[32px] lg:w-[42px] h-auto relative z-10 lamp-img transition-all duration-[700ms]"
          />
        </div>
      </div>

    </div>

    <!-- Subheading -->
    <p class="mt-[16px] md:mt-[24px] max-w-[600px] mx-auto text-center px-6
              text-[18px] md:text-[20px] lg:text-[24px] font-light leading-[140%]
              text-[var(--color-primary)] transition-colors duration-[700ms] hero-subtitle">
      Whether you're an individual, startup, or agency —
      we build tech that scales with you
    </p>

    <!-- Illustration -->
    <div class="mt-[60px] flex justify-center">
      <img
        src="/hero-illustration.svg"
        alt="Team Illustration"
        class="w-[1158px] max-w-full h-auto transition-all duration-[700ms] hero-image"
      />
    </div>

  </div>

  <!-- Smooth Bottom Fade -->
  <div class="absolute bottom-0 left-0 w-full h-[250px]
              z-0 transition-opacity duration-[700ms] bottom-fade">
  </div>

  <style>
    /* Night Mode Transitions (Global) */
    :global(html.is-night) #hero-section {
      background-color: #0B1120 !important; /* Deep Space Navy */
    }

    :global(html.is-night) .hero-title, 
    :global(html.is-night) .hero-subtitle {
      color: #F8FAFC !important;
      text-shadow: 0 0 20px rgba(56, 189, 248, 0.4);
    }

    :global(html.is-night) .lamp-glow {
      opacity: 1 !important;
      animation: pulsate 3s infinite alternate ease-in-out;
    }


    :global(html.is-night) .hero-image {
      filter: brightness(0.8) contrast(1.1) drop-shadow(0 0 25px rgba(56, 189, 248, 0.2));
    }

    :global(html.is-night) .lamp-img {
      filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.6));
    }

    .bottom-fade {
      background: linear-gradient(
        to top,
        #ffffff 0%,
        rgba(255, 255, 255, 0.98) 12%,
        rgba(255, 255, 255, 0.88) 28%,
        rgba(255, 255, 255, 0.7) 45%,
        rgba(255, 255, 255, 0.4) 65%,
        rgba(255, 255, 255, 0.1) 85%,
        transparent 100%
      );
    }

    @keyframes pulsate {
      0% { transform: translate(-50%, 0) scale(1); opacity: 0.6; }
      100% { transform: translate(-50%, 0) scale(1.3); opacity: 1; }
    }
  </style>

</section>

<script>
  import { gsap } from 'gsap';

  // Hide elements immediately via GSAP (not CSS classes) to avoid conflicts
  gsap.set(['.hero-title', '.hero-subtitle', '.hero-image'], { opacity: 0, y: 30 });

  // Reveal on page load with a staggered timeline
  const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' }, delay: 0.1 });

  heroTl
    .to('.hero-title', { opacity: 1, y: 0, duration: 0.85 })
    .to('.hero-subtitle', { opacity: 1, y: 0, duration: 0.75 }, '-=0.5')
    .to('.hero-image', { opacity: 1, y: 0, duration: 0.9 }, '-=0.5');
</script>
