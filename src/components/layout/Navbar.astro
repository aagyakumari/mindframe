---
const { class: className } = Astro.props;
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "/index.html";
---

<nav id="main-nav" data-is-home={String(isHome)} class:list={["w-full transition-colors duration-[700ms] ease-in-out z-[100] relative", className || "bg-[var(--color-bg)]"]}>

  <div class="max-w-[1440px] mx-auto
              px-6 md:px-[99px] py-[40px] md:py-[52px]
              flex items-center justify-between">

    <!-- Dynamic Logo Container -->
    <a href="/" class="block logo-wrapper min-w-[100px] md:min-w-[118px]" id="logo-container">
      <!-- SVG will be injected here by script to allow precision color control -->
      <img src="/logo.svg" alt="Mindframe Logo" class="w-[100px] md:w-[118px] h-auto transition-opacity duration-300" id="logo-placeholder" />
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-[40px]
                text-[20px] font-medium text-[var(--color-primary)]">
      <a href="/services" class="hover:text-[var(--color-accent)] transition">Services</a>
      <a href="/about" class="hover:text-[var(--color-accent)] transition">About</a>
      <a href="/work" class="hover:text-[var(--color-accent)] transition">Work</a>
    </div>

    <!-- Contact & Toggle Section -->
    <div class="hidden md:flex items-center gap-[24px]">
      <!-- Vision Toggle -->
      {isHome && (
        <button 
          id="vision-toggle"
          class="relative w-[64px] h-[32px] rounded-full bg-white/10 backdrop-blur-md border border-white/20 
                 transition-all duration-300 hover:bg-white/20 group p-1 flex items-center shadow-lg"
          aria-label="Toggle Vision"
        >
          <div class="toggle-track relative w-full h-full flex items-center">
            <!-- Sliding Knob -->
            <div class="toggle-knob absolute left-0 w-[24px] h-[24px] rounded-full bg-white shadow-md 
                        transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] flex items-center justify-center overflow-hidden">
              <!-- Sun Icon -->
              <svg class="sun-icon w-4 h-4 text-[#FFB800] absolute transition-all duration-500 opacity-100 scale-100" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464-4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.121 12.021l.707-.707a1 1 0 011.414 1.414l-.707.707a1 1 0 01-1.414-1.414zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.414l-.707-.707a1 1 0 011.414-1.414l.707.707a1 1 0 01-1.414 1.414zm1.414 8.485l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 9a1 1 0 100 2H3a1 1 0 100-2h1z" />
              </svg>
              <!-- Moon Icon -->
              <svg class="moon-icon w-4 h-4 text-[#38BDF8] absolute transition-all duration-500 opacity-0 scale-50" fill="currentColor" viewBox="0 0 20 20">
                <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
              </svg>
            </div>
          </div>
        </button>
      )}

      <a href="/contact"
         class="w-[97px] h-[33px] flex items-center justify-center text-[15px] font-medium bg-[var(--color-primary)] text-white rounded-[16px] shadow-[0_2px_8px_rgba(0,0,0,0.15)] hover:opacity-90 transition">
        Contact
      </a>
    </div>

    <!-- Mobile Menu Button & Mobile Toggle -->
    <div class="md:hidden flex items-center gap-4">
      {isHome && (
        <button id="mobile-vision-toggle" class="p-2 text-[var(--color-primary)] transition-colors">
          <!-- Simplified switch for mobile or same toggle -->
          <svg id="mobile-sun" class="w-6 h-6 sun-icon block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
          </svg>
          <svg id="mobile-moon" class="w-6 h-6 moon-icon hidden text-[#38BDF8]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
      )}
      <button id="menu-btn" class="text-[var(--color-primary)] text-2xl">☰</button>
    </div>

  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden px-6 pb-6 flex flex-col gap-6 text-[18px] font-medium bg-[var(--color-bg)]">
    <a href="/services" class="hover:text-[var(--color-accent)]">Services</a>
    <a href="/about" class="hover:text-[var(--color-accent)]">About</a>
    <a href="/work" class="hover:text-[var(--color-accent)]">Work</a>
    <a href="/contact" class="w-[120px] h-[40px] flex items-center justify-center bg-[var(--color-primary)] text-white rounded-[16px]">Contact</a>
  </div>

</nav>

<style>
  /* Night Mode Transitions for Nav */
  /* Night Mode Transitions for Nav */
  :global(html.is-night) #main-nav {
    background-color: #0B1120 !important;
  }

  /* Vision Toggle Animations */
  #vision-toggle .toggle-knob {
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
  }

  :global(html.is-night) #vision-toggle .toggle-knob {
    left: calc(100% - 28px);
    background-color: #1D375C;
  }

  :global(html.is-night) #vision-toggle .sun-icon {
    opacity: 0;
    transform: scale(0.5) rotate(90deg);
  }

  :global(html.is-night) #vision-toggle .moon-icon {
    opacity: 1;
    transform: scale(1) rotate(0);
  }

  :global(html.is-night) #mobile-sun {
    display: none;
  }

  :global(html.is-night) #mobile-moon {
    display: block;
  }

  #main-nav {
    transition: background-color 700ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(html.is-night) #main-nav a:not([href="/contact"]),
  :global(html.is-night) #menu-btn {
    color: #F8FAFC !important;
  }

  :global(html.is-night) #main-nav a:not([href="/contact"]):hover {
    color: var(--color-accent) !important;
  }

  :global(html.is-night) #main-nav #mobile-menu {
    background-color: #0B1120 !important;
  }

  /* Fade transitions for the logo injection */
  #logo-container :global(svg) {
    width: 100px;
    height: auto;
    display: block;
    transition: all 700ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @media (min-width: 768px) {
    #logo-container :global(svg) {
      width: 118px;
    }
  }
</style>

<script>
  let cachedSvg = null;

  async function injectLogo() {
    const container = document.getElementById("logo-container");
    const placeholder = document.getElementById("logo-placeholder");
    
    if (!container) return;

    try {
      if (!cachedSvg) {
        const resp = await fetch("/logo.svg");
        cachedSvg = await resp.text();
      }

      function updateLogoColors() {
        const isNight = document.documentElement.classList.contains("is-night");
        // MIND/Icon stays dark blue in day, turns white in night.
        // FRAME stays light blue #38BDF8 in both.
        const mindColor = isNight ? "#FFFFFF" : "#1D375C";
        
        let processedSvg = cachedSvg.replace(/fill="#1D375C"/g, `fill="${mindColor}"`);
        
        // Remove placeholder and inject
        if (placeholder) placeholder.style.display = 'none';
        container.innerHTML = processedSvg;
      }

      updateLogoColors();

      // Watch for theme changes
      const observer = new MutationObserver(updateLogoColors);
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });

    } catch (e) {
      console.error("Logo injection failed", e);
    }
  }

  const setupNav = () => {
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");
    btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));

    const nav = document.getElementById("main-nav");
    const isHomePage = nav?.dataset.isHome === "true";
    const html = document.documentElement;

    if (!isHomePage) {
      html.classList.remove('is-night');
    } else {
      const savedTheme = localStorage.getItem('theme');
      if (savedTheme === 'night') {
        html.classList.add('is-night');
      }
    }

    const desktopToggle = document.getElementById("vision-toggle");
    const mobileToggle = document.getElementById("mobile-vision-toggle");

    const toggleTheme = () => {
      html.classList.toggle('is-night');
      const isNight = html.classList.contains('is-night');
      localStorage.setItem('theme', isNight ? 'night' : 'day');
      
      // Update injecting logo if it exists
      if (typeof window.updateLogoColors === 'function') {
        window.updateLogoColors();
      }
    };

    desktopToggle?.addEventListener("click", toggleTheme);
    mobileToggle?.addEventListener("click", toggleTheme);

    // Initial Injection & Setup
    injectLogo();
  }

  setupNav();
  document.addEventListener('astro:after-swap', setupNav);
</script>